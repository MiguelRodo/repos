{
  "name": "Repos CLI Environment",
  
  "image": "ghcr.io/MiguelRodo/devcontainers-repos:v1.0.0",

  "customizations": {
    "vscode": {
      "extensions": [
        "golang.Go",
        "ms-python.python",
        "Posit.air-vscode",
        "github.vscode-github-actions"
      ],
      "settings": {
        "go.useLanguageServer": true,
        "go.toolsManagement.checkForUpdates": "local"
      }
    }
  }
}
